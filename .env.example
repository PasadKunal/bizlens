# Copy to .env and adjust. Never commit the real .env.

# --- Postgres ---
DATABASE_URL=postgresql+psycopg://bizlens:bizlens@localhost:5432/bizlens
# SELECT-only analyst role — used by ALL analytics queries.
ANALYST_DATABASE_URL=postgresql+psycopg://bizlens_readonly:readonly@localhost:5432/bizlens

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
KPI_CACHE_TTL_SECONDS=300

# --- Ad-hoc query sandbox ---
ADHOC_QUERY_TIMEOUT=10
ADHOC_QUERY_ROW_CAP=10000

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
# Built-in analyst accounts for local/dev use; both map to the read-only PG role
# but carry a different row-level-security scope (data-scoping demo).
#   analyst    -> scope ALL (all countries)   analyst_br -> scope BR (Brazil only)
DEV_USERNAME=analyst
DEV_PASSWORD=analyst
DEV_SCOPED_USERNAME=analyst_br
DEV_SCOPED_SCOPE=BR
ANALYST_ROLE=bizlens_readonly

# --- OpenAI (optional; falls back to template summaries if unset) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# NL-to-SQL embedding backend: "local" (hashing, offline) or "openai".
EMBED_BACKEND=local

# --- Anomaly detection ---
ANOMALY_SIGMA=2.5
